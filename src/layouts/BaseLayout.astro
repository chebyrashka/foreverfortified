---
import SiteFooter from "@/components/site/SiteFooter.vue";
import SiteHeader from "@/components/site/SiteHeader.vue";
import { company, navItems, services, subServicePages } from "@/data/site";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Forever Fortified",
  description = "Roofing, siding, gutters, and bathroom remodel services built for long-term value."
} = Astro.props;

const pageTitle = title === company.name ? title : `${title} | ${company.name}`;

const netlifyFormNames = [
  { name: "estimate", service: "General estimate" },
  ...services.map((service) => ({
    name: `service-request-${service.slug}`,
    service: service.title
  })),
  { name: "service-request-roofing-brava", service: "Brava Roof Tile" },
  ...subServicePages.map(({ service, subService }) => ({
    name: `service-request-${service.slug}-${subService.slug}`,
    service: subService.title
  }))
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="page-shell">
      <div class="netlify-form-definitions" hidden aria-hidden="true">
        {
          netlifyFormNames.map((form) => (
            <form name={form.name} method="POST" action="/thank-you/" data-netlify="true">
              <input type="hidden" name="form-name" value={form.name} />
              <input type="hidden" name="service" value={form.service} />
              <input name="name" />
              <input name="email" type="email" />
              <input name="phone" type="tel" />
              <input name="project_type" />
              <input name="location" />
              <input name="timing" />
              <textarea name="message"></textarea>
            </form>
          ))
        }
      </div>
      <SiteHeader client:load company={company} navItems={navItems} services={services} />
      <main id="main-content">
        <slot />
      </main>
      <SiteFooter company={company} navItems={navItems} services={services} />
    </div>
    <script is:inline>
      (() => {
        const localHosts = new Set(["localhost", "127.0.0.1", "::1"]);

        document.addEventListener("submit", (event) => {
          const form = event.target;

          if (!(form instanceof HTMLFormElement) || !form.matches("form[data-netlify='true']")) {
            return;
          }

          if (!localHosts.has(window.location.hostname)) {
            return;
          }

          event.preventDefault();

          const action = form.getAttribute("action") || "/thank-you/";
          window.location.assign(action);
        });
      })();
    </script>
  </body>
</html>
