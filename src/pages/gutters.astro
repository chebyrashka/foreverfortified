---
import ServicePage from "@/components/pages/ServicePage.vue";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { company, services, testimonials } from "@/data/site";

const service = services.find((item) => item.slug === "gutters");
---

<BaseLayout title="Gutters" description="Gutter replacement and drainage planning that helps protect the roofline, siding, and foundation.">
  {service && <ServicePage service={service} testimonials={testimonials} estimateUrl={company.estimateUrl} />}
</BaseLayout>
